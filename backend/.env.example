# ─── Blockchain Voting System — Environment Template ─────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Ganache local blockchain URL
GANACHE_URL=http://127.0.0.1:7545

# Smart contract address (fill after running: truffle migrate)
CONTRACT_ADDRESS=<paste-contract-address-here>

# Admin wallet private key from Ganache (Account 0)
# ⚠️ NEVER commit the real key! Get it from Ganache UI.
ADMIN_WALLET_PRIVATE_KEY=<paste-private-key-here>

# Admin panel password
ADMIN_PASSWORD=admin123

# JWT secret key for token signing (change in production!)
SECRET_KEY=your-jwt-secret-key-change-me

# Database URL (SQLite, no setup needed)
DATABASE_URL=sqlite:///./voting.db
